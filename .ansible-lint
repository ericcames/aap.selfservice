---
profile: basic

# Don't attempt to install collections from Galaxy/Hub in CI
offline: true

exclude_paths:
  - inventories/rhdp-sample-demo/

# syntax-check requires collections installed — skip it since Automation Hub
# credentials aren't available in CI. YAML quality rules still run.
skip_list:
  - syntax-check

warn_list:
  - fqcn
  - no-changed-when
